# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/skychat"

# Auth.js Configuration
AUTH_SECRET="your-super-secret-key"
AUTH_TRUST_HOST="true"

# OAuth Providers
AUTH_GOOGLE_ID="your-google-client-id"
